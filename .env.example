# ===== SeatGeek =====
# Consíguelo en https://seatgeek.com/account/develop (requiere aprobación, puede tardar días).
# Si lo dejas vacío, el bot corre en MODO DEMO con datos de prueba.
SEATGEEK_CLIENT_ID=

# ID exacto del evento (lo MÁS confiable). Se saca de la URL del evento en SeatGeek:
# seatgeek.com/.../17650335  ->  EVENT_ID=17650335
# Default: Mexico vs England, Round of 16, World Cup 2026 (Estadio Banorte, 5 jul 2026).
# Si tiene valor, se ignora la búsqueda por texto de abajo.
EVENT_ID=17650335

# (Solo se usa si EVENT_ID está vacío) Búsqueda por texto — parámetro q de la API
EVENT_QUERY=mexico england
# El título del evento debe contener TODAS estas palabras (separadas por coma). Vacío = no filtrar.
EVENT_TITLE_CONTAINS=mexico,england

# ===== Alertas =====
# Precio (en la moneda que devuelve la API, normalmente USD) por debajo del cual quieres el aviso.
# 0 = no manda alertas (solo muestra el front).
PRICE_THRESHOLD=350
POLL_INTERVAL_MINUTES=2
CURRENCY=USD

# ===== Scraping (precios reales del Mundial u otros eventos que la API no expone) =====
# API key gratis en https://www.scrapingbee.com (plan free ~1000 créditos).
# Vacío = solo API oficial (el Mundial no traerá precios).
SCRAPINGBEE_API_KEY=
# true = proxy "stealth" (75 créditos/consulta, necesario para SeatGeek/Cloudflare). false = premium (25).
SCRAPINGBEE_STEALTH=true
# Ventana horaria para AHORRAR créditos: fuera de estas horas NO consulta (0 créditos).
# 0 y 24 = siempre. Ej: de 7am a medianoche -> START=7, END=24. Hora en la zona de abajo.
SCRAPE_START_HOUR=0
SCRAPE_END_HOUR=24
SCRAPE_TZ=America/Mexico_City
# Fuentes de precio (una card por cada una). Cada fuente = 1 consulta (75 créditos con stealth).
# Formato: "Etiqueta|url;;Etiqueta|url". Vacío = usa las de por defecto (SeatGeek + Viagogo).
# Ej: SOURCES=SeatGeek|https://seatgeek.com/...;;Viagogo|https://www.viagogo.com.mx/...
SOURCES=

# ===== Telegram =====
# Token del bot creado con @BotFather
TELEGRAM_BOT_TOKEN=
# Tu chat_id: pon el token arriba, mándale un mensaje al bot y corre `npm run chatid`
TELEGRAM_CHAT_ID=
