# ===== SeatGeek =====
# Consíguelo en https://seatgeek.com/account/develop (requiere aprobación, puede tardar días).
# Si lo dejas vacío, el bot corre en MODO DEMO con datos de prueba.
SEATGEEK_CLIENT_ID=

# ID exacto del evento (lo MÁS confiable). Se saca de la URL del evento en SeatGeek:
# seatgeek.com/.../17650335  ->  EVENT_ID=17650335
# Default: Mexico vs England, Round of 16, World Cup 2026 (Estadio Banorte, 5 jul 2026).
# Si tiene valor, se ignora la búsqueda por texto de abajo.
EVENT_ID=17650335

# (Solo se usa si EVENT_ID está vacío) Búsqueda por texto — parámetro q de la API
EVENT_QUERY=mexico england
# El título del evento debe contener TODAS estas palabras (separadas por coma). Vacío = no filtrar.
EVENT_TITLE_CONTAINS=mexico,england

# ===== Alertas =====
# Precio (en la moneda que devuelve la API, normalmente USD) por debajo del cual quieres el aviso.
# 0 = no manda alertas (solo muestra el front).
PRICE_THRESHOLD=350
POLL_INTERVAL_MINUTES=2
CURRENCY=USD

# ===== Telegram =====
# Token del bot creado con @BotFather
TELEGRAM_BOT_TOKEN=
# Tu chat_id: pon el token arriba, mándale un mensaje al bot y corre `npm run chatid`
TELEGRAM_CHAT_ID=
